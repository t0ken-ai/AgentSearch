# AgentSearch HTTP API config — copy to /etc/agentsearch/env, mode 0600,
# owned by agentsearch:agentsearch.
#
#   sudo install -m 600 -o agentsearch -g agentsearch \
#       deploy/systemd/env.example /etc/agentsearch/env
#   # then edit and fill in the secrets

# ── Auth ───────────────────────────────────────────────────────────────
# Bearer token clients send: Authorization: Bearer $AGENTSEARCH_TOKEN
# Generate a fresh one with: openssl rand -hex 32
AGENTSEARCH_TOKEN=REPLACE_WITH_RANDOM_HEX

# ── Proxy (optional) ───────────────────────────────────────────────────
# If your server's IP is in a datacenter range, Meta / TikTok / Google
# ad libraries will rate-limit or 401 you. Route through a residential
# proxy (Fluxisp, Oxylabs, Bright Data, IPRoyal, …) to avoid this.
# Leave commented out to run direct.
# FLUXISP_PROXY=http://USER:PASS@us-eu.fluxisp.com:5000

# ── Logging ────────────────────────────────────────────────────────────
AGENTSEARCH_LOG=INFO

# ── Browser recycling cadence ──────────────────────────────────────────
# How many search/extract calls to serve from one CloakBrowser before
# recycling. Default 25; lower if you see cookie / JS-world drift.
# AGENTSEARCH_RECYCLE_AFTER=25
